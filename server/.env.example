APP_NAME=Book & Notes Management System
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/book_notes_management
JWT_ACCESS_SECRET=replace-this-with-a-very-long-random-string
JWT_REFRESH_SECRET=replace-this-with-another-very-long-random-string
JWT_ACCESS_EXP_MINUTES=15
JWT_REFRESH_EXP_DAYS=7
JWT_ALGORITHM=HS256
REFRESH_COOKIE_NAME=book_notes_refresh_token
SESSION_SECRET=replace-this-with-a-long-random-session-secret
BCRYPT_ROUNDS=12
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
RATE_LIMIT_WINDOW_SECONDS=900
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX_REQUESTS=20
